__pycache__/
*.pyc
*.egg-info/
.venv/
runs/
docs/
analyses/
checkpoints/
*.ckpt
*.pt
*.pth
*.tar
wandb/
.DS_Store
.claude/

# Backbone repos (cloned, not tracked — clone on each machine)
src/piano/models/backbones/momask/

# External upstream repos used as local references/adapters. Keep them
# reproducible but out of project source control.
src/external/
external/

# Project-memory / planning / analyses .md files: kept locally, not
# part of the remote repo. Only README.md (at any depth) is tracked.
*.md
!README.md
!**/README.md

# Local single-machine cache (CLIP weights, HF cache, torch hub, etc).
# Workspace-local but should not be committed.
cache/

# Local-machine training configs / accelerate configs. Server runs use
# the non-_local versions of each yaml. Local variants typically have
# Windows paths and single-GPU dynamics tuning, so they don't belong
# in the shared repo. Keep them in the working tree for personal use.
configs/accelerate_local_*.yaml
configs/training/*_local.yaml

# Local-machine launch scripts (PowerShell, Windows-specific paths).
# Server uses bash + paths in PLAN.md.
scripts/**/run_*_local_*.ps1
*.ps1
